<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no, maximum-scale=1"/>

<title>Florida Hurricane Season: Does Your Patio Door Meet Code? | MP Doors Blog</title>
<meta name="description" content="Is your Florida patio door rated for its windborne debris zone? How FBC product approval works, what FL-29714 (DP +50/−50, TAS 201/202/203) means, and how to confirm the right MP Doors Impact Hinged configuration before you order."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400&family=Open+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css"/>
<link rel="stylesheet" href="/assets/css/style.css?v=3"/>

<style id="mobile-v4">

/* ── New elements: invisible on desktop ──────── */
.m-nav,
.m-nav-overlay { display: none; }

@media (max-width: 768px) {

  /* ═══════════════════════════════════════════
     1. HEADER / HAMBURGER MENU
  ═══════════════════════════════════════════ */

  /* Hide desktop nav & Shop CTA; show hamburger */
  .header-list,
  .nav-cta { display: none !important; }

  /* Refined floating-lines hamburger — no container, no system appearance */
  .hamburger {
    -webkit-appearance: none; appearance: none;
    background: transparent !important;
    border: none !important; border-radius: 0 !important;
    box-shadow: none !important; outline: none;
    display: flex !important; flex-direction: column;
    align-items: flex-start; justify-content: center;
    gap: 6px; padding: 8px 6px !important;
    cursor: pointer; position: relative; z-index: 1002;
  }

  /* Slim the header bar on mobile */
  .header-box .container { height: 60px; }
  .logo-wrap img { height: 36px !important; }

  /* Three lines: top & bottom full-width, middle shorter — refined visual rhythm */
  .hamburger span {
    display: block; border-radius: 2px;
    background: #240F00;
    transition: transform .3s ease, opacity .22s ease, width .25s ease, background .2s ease;
    transform-origin: center;
  }
  .hamburger span:nth-child(1) { width: 22px; height: 2px; }
  .hamburger span:nth-child(2) { width: 14px; height: 2px; }
  .hamburger span:nth-child(3) { width: 22px; height: 2px; }

  /* × morph — gap:6px + height:2px → center-to-center = 8px */
  .hamburger.is-open span:nth-child(1) { transform: translateY(8px) rotate(45deg); width: 22px; }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); width: 22px; }

  /* ── Dimmed overlay behind drawer ── */
  .m-nav-overlay {
    display: block;
    position: fixed; inset: 0; z-index: 1001;
    background: rgba(26, 8, 0, 0.52);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0; visibility: hidden;
    transition: opacity .3s ease, visibility .3s ease;
  }
  .m-nav-overlay.is-open { opacity: 1; visibility: visible; }

  /* ── Slide-in drawer panel ── */
  .m-nav {
    display: flex;
    flex-direction: column;
    position: fixed; top: 0; right: 0; bottom: 0;
    z-index: 1002;
    width: min(84vw, 340px);
    background: linear-gradient(160deg, #FFFBF5 0%, #FFF1E0 100%);
    box-shadow: -18px 0 56px rgba(26, 8, 0, 0.3);
    border-left: 1px solid rgba(242, 148, 48, 0.2);
    transform: translateX(100%);
    transition: transform .34s cubic-bezier(.4, 0, .2, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .m-nav.is-open { transform: translateX(0); }

  /* Drawer header bar (sticky inside drawer) */
  .m-nav-head {
    display: flex; align-items: center; justify-content: space-between;
    height: 60px; padding: 0 20px;
    border-bottom: 1px solid rgba(242, 148, 48, 0.16);
    position: sticky; top: 0; z-index: 1; flex-shrink: 0;
    background: rgba(255, 251, 245, 0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .m-nav-head img { height: 32px; width: auto; }

  .m-nav-close {
    background: none; border: none; cursor: pointer;
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; line-height: 1; color: var(--text-mid);
    transition: background .2s;
  }
  .m-nav-close:active { background: rgba(242, 148, 48, .12); }

  /* Nav group accordion rows */
  .m-nav-links { padding: 6px 0 24px; flex: 1; }
  .m-nav-group { border-bottom: 1px solid rgba(242, 148, 48, .1); }

  .m-nav-toggle {
    width: 100%;
    display: flex; align-items: center; justify-content: space-between;
    background: none; border: none; cursor: pointer; text-align: left;
    font-family: 'EB Garamond', serif;
    font-size: 1.15rem; font-weight: 600;
    color: var(--text-dark); padding: 15px 20px;
    transition: color .2s;
  }
  .m-nav-toggle .m-chev {
    width: 18px; height: 18px; flex-shrink: 0;
    color: var(--primary);
    transition: transform .28s ease;
  }
  .m-nav-group.is-open > .m-nav-toggle { color: var(--primary); }
  .m-nav-group.is-open .m-chev { transform: rotate(180deg); }

  /* Sub-menu accordion slide */
  .m-nav-sub {
    max-height: 0; overflow: hidden;
    transition: max-height .32s ease;
    background: rgba(242, 148, 48, .04);
  }
  .m-nav-group.is-open > .m-nav-sub { max-height: 500px; }

  .m-nav-sub a {
    display: block;
    padding: 12px 20px 12px 32px;
    font-size: 0.93rem; font-weight: 600;
    color: var(--text-mid);
    border-top: 1px solid rgba(242, 148, 48, .08);
    transition: color .2s, background .2s;
  }
  .m-nav-sub a:active { color: var(--primary); background: rgba(242, 148, 48, .1); }

  /* SHOP NOW CTA — sits inside nav, below last group */
  .m-nav-shop {
    display: flex; align-items: center; justify-content: center;
    margin: 20px 20px 24px; padding: 14px 24px; border-radius: 50px;
    background: var(--primary); color: #fff; text-decoration: none;
    font-family: 'EB Garamond', serif; font-weight: 700; font-size: 1rem;
    letter-spacing: .02em;
    box-shadow: 0 8px 22px rgba(242, 148, 48, .4);
    transition: background .2s;
  }
  .m-nav-shop:active { background: var(--primary-dark); }

  /* Lock body scroll while drawer is open */
  body.m-nav-locked { overflow: hidden; touch-action: none; }

  /* ═══════════════════════════════════════════
     2. HERO SECTION
  ═══════════════════════════════════════════ */

  /* Use svh so the hero doesn't over-shoot on iOS (address-bar gap) */
  .head-section { min-height: 100svh; }

  /* Cut the generous desktop vertical padding */
  .head-wrap { padding: 48px 0 60px; }
  .head-content { max-width: 100%; }

  /* Tighter headline at phone sizes */
  .head-content h1 {
    font-size: clamp(1.9rem, 7.8vw, 2.65rem) !important;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  /* Badge margin = 4 × (1rem × 0.7 line-leading) = 2.8rem, equal top & bottom */
  .hero-badge { margin: 2.8rem auto; }
  .head-content .hero-para { font-size: 1rem; line-height: 1.7; }

  /* Full-width stacked buttons */
  .head-actions {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    margin-top: 28px;
  }
  .head-actions .button {
    width: 100%;
    justify-content: center;
    padding: 15px 20px;
  }

  /* 3-column stat grid (tight but readable on ≥375px) */
  .hero-stats {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px 10px;
    margin-top: 36px;
    padding-top: 28px;
  }
  .hero-stat-num  { font-size: 1.75rem !important; letter-spacing: -0.02em; }
  .hero-stat-label { font-size: 0.67rem; line-height: 1.35; }

  /* ═══════════════════════════════════════════
     3. BRAND INTRO (who-container)
  ═══════════════════════════════════════════ */
  /* Already collapses to 1-col at 1024px; just tighten the gap */
  .who-container { gap: 28px; }

  /* ═══════════════════════════════════════════
     4. DARK FEATURES — VIDEO + ACCORDION
     Layout handled by existing 1024px breakpoint in style.css.
     Only reduce the video height slightly from its default 340px.
  ═══════════════════════════════════════════ */
  .acc-left-right.acc-bleed .sticky-video { height: 285px !important; }

  /* Tighten accordion item spacing */
  .faq-wrap { padding: 24px 0; }

  /* ═══════════════════════════════════════════
     5. MASTERPIECE SERIES cards
  ═══════════════════════════════════════════ */
  /* .g-4 already → 1fr at 768px via style.css; just tune padding */
  .agent-card { padding: 28px 22px; }
  .agent-icon { width: 52px; height: 52px; }
  .agent-icon svg { width: 26px; height: 26px; }

  /* ═══════════════════════════════════════════
     6. FIND YOUR DOOR  (inline-style override via class)
  ═══════════════════════════════════════════ */
  .find-door-grid {
    grid-template-columns: 1fr !important;
  }
  .find-door-grid > a {
    min-height: 200px !important;
    padding: 36px 28px !important;
  }
  .find-door-grid > a h3 {
    font-size: clamp(1.3rem, 5.5vw, 1.7rem) !important;
  }

  /* ═══════════════════════════════════════════
     7. BUYER PROOF GRID  (inline-style override via class)
  ═══════════════════════════════════════════ */
  .proof-grid {
    grid-template-columns: 1fr !important;
  }
  .proof-grid > div {
    padding: 28px 24px !important;
  }
  .proof-grid > div h3 {
    font-size: 1.2rem !important;
  }

  /* ═══════════════════════════════════════════
     8. DIFFERENTIATOR STATEMENT
  ═══════════════════════════════════════════ */
  .media-section .sec-title {
    font-size: clamp(1.5rem, 6.5vw, 2.2rem) !important;
    margin-bottom: 20px !important;
  }

  /* ═══════════════════════════════════════════
     9. PILLAR CARDS (after-installation)
  ═══════════════════════════════════════════ */
  .pillar-header { margin-bottom: 40px; }
  .pillar-scroll-wrap { gap: 16px; }

  /* Collapse the 2-column card to a single column */
  .gf-card {
    grid-template-columns: 1fr !important;
    padding: 32px 22px !important;
    gap: 24px !important;
  }
  .gf-card:nth-child(even) .gf-content { order: unset !important; }
  .gf-card:nth-child(even) .gf-img    { order: unset !important; }

  /* Tighten icon circles */
  .pillar-icon-wrap { width: 90px; height: 90px; }
  .pillar-icon-wrap svg { width: 44px; height: 44px; }

  /* font scale for card titles */
  .font40r { font-size: clamp(1.25rem, 5.8vw, 1.9rem) !important; }

  /* ═══════════════════════════════════════════
     10. TESTIMONIALS
  ═══════════════════════════════════════════ */
  .testimonial-content-wrapper { padding: 32px 22px !important; }
  /* Pull the decorative quote glyph in so it doesn't collide */
  .testimonial-content-wrapper::before {
    font-size: 5rem; top: 12px; right: 20px;
  }
  .testimonial-quote p { font-size: 0.94rem !important; }

  /* ═══════════════════════════════════════════
     11. FAQ ACCORDION  (inline-style padding override via class)
  ═══════════════════════════════════════════ */
  .faq-accordion summary {
    padding: 18px 20px !important;
    font-size: 0.9rem !important;
  }
  .faq-accordion details > div {
    padding: 0 20px 20px !important;
  }

  /* ═══════════════════════════════════════════
     12. PRE-FOOTER CTA
  ═══════════════════════════════════════════ */
  .pre-footer-wrap { min-height: 0; }
  .pre-footer-content { padding: 40px 24px !important; }

  /* Stack the button(s) full-width */
  .pre-footer-btn {
    flex-direction: column;
    align-items: stretch;
  }
  .pre-footer-btn .button.orange {
    width: 100%;
    justify-content: center;
  }

  /* ═══════════════════════════════════════════
     13. FOOTER
  ═══════════════════════════════════════════ */
  /* footer-content already → grid-template-columns:1fr at 768px (style.css line 786) */
  .footer { padding: 52px 0 32px; }

  /* ═══════════════════════════════════════════
     14. GLOBAL RHYTHM
  ═══════════════════════════════════════════ */
  .comm-section { padding: 72px 0 !important; }
  .sec-head.centered { margin-bottom: 44px !important; }
}
</style>

<!-- V3: mobile overflow guard + collapse inline multi-column grids (additive, ≤768px) -->
<style id="mobile-grid-fix">
@media (max-width: 768px) {
  /* stop any element from forcing horizontal scroll (white gap on the right).
     overflow-x:clip (not hidden) so position:sticky keeps working. */
  html, body { overflow-x: clip; }
  [style*="repeat("],
  [style*="1fr 1fr"],
  [style*="1fr 2fr"],
  [style*="2fr 1fr"],
  [style*="1fr 1.5fr"],
  [style*="1.5fr 1fr"] { grid-template-columns: 1fr !important; }
}
</style>

<!-- ══ FOOTER v3 styles (additive; supersedes old .footer) ══ -->
<style id="footer-v3">
/* ══════════════════════════════════════════════════════════
   MP DOORS — FOOTER v3  (warm, site-aligned)
   Zone 1 trust strip · Zone 2 dark body · Zone 3 bottom bar.
   Uses the site's :root vars (present on every page).
   Injected as <style id="footer-v3"> after style.css → supersedes
   the old .footer rules; old .footer-content/.footer-col are inert.
══════════════════════════════════════════════════════════ */

/* Zone 1 — trust strip */
.footer-trust-strip{
  /* fallback gradient for pages that don't define --grad-cream (e.g. impact landing) */
  background:var(--grad-cream, linear-gradient(165deg,#FDF8F2 0%,#FBF1E5 55%,#F7E9D8 100%));
  border-top:1px solid rgba(196,117,32,0.15);
  padding:32px 0;
}
.footer-trust-inner{
  display:flex; align-items:center; justify-content:space-between;
  gap:24px; flex-wrap:wrap;
}
.footer-trust-facts{
  display:flex; align-items:center; gap:36px; flex-wrap:wrap;
}
.footer-trust-fact{
  display:flex; align-items:center; gap:10px;
}
.footer-trust-fact-icon{
  width:34px; height:34px; flex-shrink:0; border-radius:50%;
  background:rgba(242,148,48,0.12); display:flex; align-items:center; justify-content:center;
}
.footer-trust-fact-icon svg{ width:17px; height:17px; stroke:var(--primary); fill:none; }
.footer-trust-fact span{
  font-family:'EB Garamond',serif; font-size:0.92rem; font-weight:600;
  color:var(--primary-deep); white-space:nowrap;
}
.footer-trust-cta{
  display:inline-flex; align-items:center; gap:8px; flex-shrink:0;
  padding:13px 28px; border-radius:50px;
  background:var(--primary); color:#fff; font-family:'EB Garamond',serif;
  font-weight:700; font-size:1.05rem; letter-spacing:0.04em;
  border:2px solid var(--primary); box-shadow:0 6px 20px rgba(242,148,48,0.35);
  transition:var(--transition);
}
.footer-trust-cta:hover{
  background:var(--primary-dark); border-color:var(--primary-dark);
  transform:translateY(-2px); box-shadow:0 10px 28px rgba(242,148,48,0.45);
}
.footer-trust-cta svg{ width:14px; height:14px; fill:#fff; flex-shrink:0; }

/* Zone 2 — footer body */
.footer{
  background:linear-gradient(135deg, var(--bg-dark) 0%, #2E1200 100%);
  padding:80px 0 0; position:relative; overflow:hidden;
}
.footer::before{
  content:''; position:absolute; top:-120px; right:-80px;
  width:600px; height:600px; border-radius:50%;
  background:radial-gradient(circle, rgba(242,148,48,0.18) 0%, transparent 65%);
  pointer-events:none;
}
.footer-body{ position:relative; z-index:1; }
.footer-grid{
  display:grid;
  grid-template-columns:1.6fr 1fr 0.9fr 1.3fr;
  gap:56px; align-items:start;
}

/* Col 1 — brand anchor */
.footer-brand{}
.footer-logo-wrap{ margin-bottom:22px; }
.footer-logo-wrap img{ height:38px; width:auto; }
.footer-brand-stmt{
  font-family:'EB Garamond',serif; font-style:italic; font-size:1.02rem;
  line-height:1.75; color:rgba(255,255,255,0.70); max-width:280px; margin-bottom:22px;
}
.footer-thd-mention{
  display:inline-flex; align-items:center; gap:8px;
  font-family:'EB Garamond',serif; font-size:0.88rem;
  color:rgba(242,148,48,0.80); letter-spacing:0.01em;
}
.footer-thd-mention::before{
  content:''; display:inline-block; width:6px; height:6px;
  background:var(--primary); border-radius:50%; flex-shrink:0;
}

/* Col 2, 3 — nav columns */
.footer-col-head{
  font-family:'EB Garamond',serif; font-size:1.05rem; font-weight:600;
  letter-spacing:0.01em; margin-bottom:22px; display:block;
  background:linear-gradient(140deg, #FFF6EA 22%, var(--accent) 62%, var(--primary) 100%);
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.footer-nav-list{ display:flex; flex-direction:column; gap:12px; list-style:none; }
.footer-nav-list a{
  font-family:'EB Garamond',serif; font-size:1rem; color:rgba(255,255,255,0.62);
  display:flex; align-items:center; gap:8px; transition:var(--transition);
}
.footer-nav-list a:hover{ color:var(--primary); padding-left:4px; }
.footer-nav-list a svg{ width:11px; height:11px; stroke:currentColor; fill:none; flex-shrink:0; opacity:0.5; }
.footer-nav-list a:hover svg{ opacity:1; }

/* Col 4 — where to buy */
.footer-buy{}
.footer-buy-stmt{
  font-family:'EB Garamond',serif; font-style:italic; font-size:0.97rem;
  line-height:1.75; color:rgba(255,255,255,0.68); margin-bottom:26px;
}
.footer-shop-btn{
  display:inline-flex; align-items:center; gap:8px;
  padding:14px 30px; border-radius:50px;
  background:#fff; color:var(--text-dark);
  font-family:'EB Garamond',serif; font-weight:700;
  font-size:1.05rem; letter-spacing:0.04em;
  box-shadow:0 6px 20px rgba(0,0,0,0.22);
  transition:var(--transition); margin-bottom:22px; white-space:nowrap;
}
.footer-shop-btn:hover{ background:#F2EADD; transform:translateY(-2px); box-shadow:0 10px 28px rgba(0,0,0,0.30); }
.footer-shop-btn svg{ width:13px; height:13px; stroke:var(--text-dark); fill:none; }
.footer-support-hint{
  font-size:0.82rem; font-family:'EB Garamond',serif;
  color:rgba(255,255,255,0.42); line-height:1.65;
}
.footer-support-hint a{
  color:rgba(242,148,48,0.72); border-bottom:1px solid rgba(242,148,48,0.25);
  padding-bottom:1px; transition:var(--transition);
}
.footer-support-hint a:hover{ color:var(--primary); border-color:var(--primary); }

/* Zone 3 — bottom bar */
.footer-bottom{
  position:relative; z-index:1;
  display:flex; justify-content:space-between; align-items:center;
  flex-wrap:wrap; gap:12px;
  margin-top:64px; padding:22px 0;
  border-top:1px solid rgba(255,255,255,0.07);
}
.footer-bottom-left{
  display:flex; align-items:center; gap:16px; flex-wrap:wrap;
}
.footer-bottom-left p{
  font-size:0.76rem; color:rgba(255,255,255,0.32);
  font-family:'Open Sans',sans-serif;
}
.footer-bottom-left .footer-bottom-sep{
  width:3px; height:3px; border-radius:50%;
  background:rgba(255,255,255,0.18); flex-shrink:0;
}
.footer-bottom-left .footer-thd-bottom{
  font-size:0.76rem; color:rgba(242,148,48,0.45);
  font-family:'Open Sans',sans-serif;
}
.footer-bottom-links{ display:flex; gap:20px; align-items:center; }
.footer-bottom-links a{
  font-size:0.76rem; color:rgba(255,255,255,0.28);
  font-family:'Open Sans',sans-serif; transition:var(--transition);
}
.footer-bottom-links a:hover{ color:rgba(255,255,255,0.60); }
.footer-bottom-links .dot-sep{
  font-size:0.5rem; color:rgba(255,255,255,0.18);
}

/* footer responsive */
@media(max-width:1024px){
  .footer-grid{ grid-template-columns:1fr 1fr; gap:44px; }
  .footer-trust-facts{ gap:24px; }
}
@media(max-width:768px){
  .footer-grid{ grid-template-columns:1fr; gap:36px; }
  .footer-trust-inner{ flex-direction:column; align-items:flex-start; gap:20px; }
  .footer-trust-facts{ flex-direction:column; gap:16px; }
  .footer-trust-fact span{ white-space:normal; }
  .footer-bottom{ flex-direction:column; align-items:flex-start; gap:10px; }
}

/* ── finalized adjustments (merged from review) ── */
.footer-logo-wrap img { height: 50px; }                      /* was 38px */
.footer-brand-stmt { font-weight: 700; font-size: 1.12rem; } /* bold + larger, keeps italic */
.footer-trust-fact span { font-size: 1.05rem; }              /* base/mobile */
@media (min-width: 769px) { .footer-trust-fact span { font-size: 1.2rem; } }  /* desktop bigger */
@media (max-width: 768px) { .footer-trust-facts { align-items: flex-start; } } /* mobile: align icons at start */
</style>
<!-- Blog / article styles (warm, site-aligned; echoes the product hero) -->
<style id="blog-style">
.article-hero{ position:relative; overflow:hidden; background:linear-gradient(135deg,var(--bg-dark) 0%,#2E1200 100%); padding:220px 0 142px; }
.article-hero::before{ content:''; position:absolute; top:-140px; right:-110px; width:620px; height:620px; border-radius:50%; background:radial-gradient(circle, rgba(242,148,48,0.18) 0%, transparent 62%); pointer-events:none; }
/* second glow, centred behind the title, so the heading feels illuminated */
.article-hero::after{ content:''; position:absolute; top:38%; left:50%; transform:translate(-50%,-50%); width:760px; height:420px; background:radial-gradient(ellipse at center, rgba(242,148,48,0.16) 0%, transparent 68%); pointer-events:none; }
.article-hero .hero-hex-grid{ opacity:0.22; }
/* centred hero content (matches the product-page hero) */
.article-hero-inner{ position:relative; z-index:1; max-width:820px; margin:0 auto; text-align:center; }
.article-title{ font-family:'Merriweather',serif; font-weight:700; color:#fff; font-size:clamp(2rem,4.6vw,3.15rem); line-height:1.16; letter-spacing:-0.015em;
  /* gap to the badge = 4× the .article-meta line-height (0.92rem × 1.5) */
  margin-bottom:calc(0.92rem * 1.5 * 4);
  text-shadow:0 0 9px rgba(255,255,255,0.75), 0 0 20px rgba(242,148,48,0.6), 0 2px 18px rgba(0,0,0,0.35); }
.article-hero .hero-badge{ margin:0 auto; }
/* meta line-height is the 1× baseline; its top gap to the badge = 4× that */
.article-meta{ font-family:'Open Sans',sans-serif; font-size:0.92rem; line-height:1.5; color:rgba(255,255,255,0.6); margin-top:calc(0.92rem * 1.5 * 4); }
.article-meta strong{ color:rgba(255,255,255,0.85); font-weight:600; }
.article-meta a{ color:var(--primary); font-weight:600; }

.article-wrap{ background:var(--grad-soft); padding-bottom:96px; }
.img-placeholder{ color:#9a8467; font-family:'EB Garamond',serif; font-size:0.95rem; text-align:center; padding:20px; }

.article-body{ max-width:760px; margin:0 auto; padding:76px 0 0; }
.article-body > p{ font-family:'Open Sans',sans-serif; font-size:1.08rem; line-height:1.86; color:#3c2a1b; margin-bottom:1.5rem; }
/* lede — first paragraph reads larger, like the product-page intro */
.article-body > p:first-of-type{ font-size:1.22rem; line-height:1.82; color:var(--text-dark); border-top:4px solid #F29430; padding-top:1.5rem; }
.article-figure{ margin:2.6rem 0; border-radius:16px; overflow:hidden; box-shadow:var(--shadow); background:#EFE3D2; }
.article-figure img{ width:100%; height:auto; display:block; }
.article-body h2{ font-family:'Merriweather',serif; font-weight:700; font-size:clamp(1.4rem,2.6vw,1.9rem); color:var(--text-dark); line-height:1.3; margin:2.7rem 0 1rem; }
.article-body strong{ color:var(--text-dark); font-weight:700; }
.article-body a{ color:var(--primary-dark); font-weight:600; text-decoration:underline; text-underline-offset:2px; text-decoration-color:rgba(242,148,48,0.5); transition:var(--transition); }
.article-body a:hover{ color:var(--primary); text-decoration-color:var(--primary); }
.article-body ul{ list-style:none; padding-left:0; margin:0 0 1.5rem; }
.article-body li{ position:relative; padding-left:26px; margin-bottom:0.7rem; font-size:1.08rem; line-height:1.75; color:#3c2a1b; }
.article-body li::before{ content:'›'; position:absolute; left:6px; top:-1px; color:var(--primary); font-weight:700; font-size:1.25rem; }

.article-callout{ background:linear-gradient(155deg,#FFFFFF,#FFF7EC); border:2px solid rgba(242,148,48,0.34); border-left:6px solid var(--primary); border-radius:14px; padding:26px 28px; margin:0.4rem 0 1.9rem; box-shadow:var(--shadow); }
.article-callout h3{ font-family:'Merriweather',serif; font-size:1.02rem; color:var(--text-dark); margin-bottom:16px; }
.article-callout .cert-row{ display:flex; gap:14px; align-items:baseline; margin-bottom:11px; font-size:0.98rem; color:#3c2a1b; line-height:1.5; }
.article-callout .cert-row:last-child{ margin-bottom:0; }
.article-callout .cert-row b{ color:var(--primary-deep); font-weight:700; flex-shrink:0; min-width:88px; }
.article-callout .cert-num{ font-family:'Merriweather',serif; font-size:1.25rem; font-weight:700; color:var(--primary-dark); }

.article-cta{ margin:72px auto 0; max-width:760px; background:linear-gradient(155deg,#2E1500,#200d00); border-radius:18px; padding:64px 56px; text-align:center; position:relative; overflow:hidden; box-shadow:0 24px 60px rgba(0,0,0,0.28); }
.article-cta::after{ content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 50% at 85% 15%, rgba(242,148,48,0.16), transparent 55%); pointer-events:none; }
.article-cta h3{ font-family:'Merriweather',serif; color:#fff; font-size:clamp(1.35rem,2.4vw,1.75rem); margin-bottom:18px; position:relative; }
.article-cta p{ color:rgba(255,255,255,0.72); font-size:1rem; line-height:1.75; margin:0 auto 36px; max-width:560px; position:relative; }
.article-cta .cta-actions{ display:flex; gap:18px; justify-content:center; flex-wrap:wrap; position:relative; }
/* glowing CTA buttons — echoes the article title's white + orange radiance */
.article-cta .cta-actions .button{ box-shadow:0 0 12px rgba(255,255,255,0.30), 0 0 26px rgba(242,148,48,0.55), 0 0 52px rgba(242,148,48,0.30); transition:box-shadow .3s ease, transform .3s ease; }
.article-cta .cta-actions .button:hover{ transform:translateY(-2px); box-shadow:0 0 16px rgba(255,255,255,0.45), 0 0 36px rgba(242,148,48,0.72), 0 0 68px rgba(242,148,48,0.42); }

/* Blog index — featured card + grid */
.blog-section{ background:var(--white); padding:72px 0 100px; }
.blog-featured{ display:grid; grid-template-columns:1.05fr 1fr; background:var(--white); border:1px solid var(--grey-border); border-radius:var(--radius-lg); overflow:hidden; text-decoration:none; box-shadow:var(--shadow-soft); transition:var(--transition); }
.blog-featured:hover{ transform:translateY(-4px); box-shadow:var(--shadow); border-color:rgba(242,148,48,0.3); }
.blog-featured-img{ min-height:340px; background:linear-gradient(135deg,#EFE3D2,#E3D2BB); display:flex; align-items:center; justify-content:center; overflow:hidden; }
.blog-featured-img img{ width:100%; height:100%; object-fit:cover; display:block; }
.blog-featured-body{ padding:48px 44px; display:flex; flex-direction:column; justify-content:center; gap:14px; }
.blog-featured-meta{ font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--primary); }
.blog-featured-body h2{ font-family:'Merriweather',serif; font-size:clamp(1.4rem,2.4vw,2rem); line-height:1.3; color:var(--text-dark); }
.blog-featured-body p{ font-size:1rem; color:var(--text-mid); line-height:1.7; }
.blog-featured-cta{ margin-top:6px; font-size:0.78rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--primary); display:inline-flex; align-items:center; gap:6px; }
.blog-featured:hover .blog-featured-cta{ gap:11px; }

@media (max-width:768px){
  .article-hero{ padding:158px 0 94px; }
  .article-hero::after{ width:110%; }
  .article-body{ padding-top:48px; }
  .article-body > p, .article-body li{ font-size:1rem; line-height:1.8; }
  .article-body > p:first-of-type{ font-size:1.1rem; }
  .article-figure{ margin:2rem 0; border-radius:12px; }
  .article-callout{ padding:22px 20px; }
  .article-callout .cert-row{ flex-direction:column; gap:2px; }
  .article-cta{ padding:48px 26px; }
  .blog-featured{ grid-template-columns:1fr; }
  .blog-featured-img{ min-height:210px; }
  .blog-featured-body{ padding:30px 24px; }
}
</style>
</head>
