<!-- V3 mobile nav drawer controller (additive) -->
<script>
(function () {
  var hamburger = document.querySelector('.hamburger');
  var nav       = document.getElementById('mNav');
  var overlay   = document.getElementById('mNavOverlay');
  var closeBtn  = document.getElementById('mNavClose');

  if (!hamburger || !nav) return;

  function openNav() {
    hamburger.classList.add('is-open');
    nav.classList.add('is-open');
    overlay.classList.add('is-open');
    document.body.classList.add('m-nav-locked');
    nav.setAttribute('aria-hidden', 'false');
  }
  function closeNav() {
    hamburger.classList.remove('is-open');
    nav.classList.remove('is-open');
    overlay.classList.remove('is-open');
    document.body.classList.remove('m-nav-locked');
    nav.setAttribute('aria-hidden', 'true');
  }

  hamburger.addEventListener('click', function () {
    nav.classList.contains('is-open') ? closeNav() : openNav();
  });
  if (closeBtn) closeBtn.addEventListener('click', closeNav);
  if (overlay)  overlay.addEventListener('click', closeNav);

  document.querySelectorAll('.m-nav-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var group  = this.closest('.m-nav-group');
      var isOpen = group.classList.contains('is-open');
      document.querySelectorAll('.m-nav-group').forEach(function (g) {
        g.classList.remove('is-open');
        g.querySelector('.m-nav-toggle').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        group.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  nav.querySelectorAll('.m-nav-sub a, .m-nav-shop').forEach(function (a) {
    a.addEventListener('click', closeNav);
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeNav();
  });
})();
</script>

</body>
</html>
